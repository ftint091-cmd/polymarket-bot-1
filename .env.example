# Polymarket Bot - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# === EXECUTION MODE ===
# Set to "paper" for safe simulation (default)
# Set to "fake_real" for integration testing
# Set to "real" ONLY with extreme caution
BOT_EXECUTION_MODE=paper

# === SAFETY GUARD ===
# Must be explicitly set to "true" to enable real trading
# Leave as "false" or unset for paper mode
ENABLE_REAL_TRADING=false

# === BOT SETTINGS ===
BOT_PROFILE=default
CONFIG_DIR=config
LOG_LEVEL=INFO

# === POLYMARKET API ===
# Required only for real trading mode
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_WALLET_ADDRESS=

# === BINANCE API (Reference Data) ===
# Optional - used for market context
BINANCE_API_KEY=
BINANCE_API_SECRET=
