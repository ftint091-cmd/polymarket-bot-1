# Polymarket Bot - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# === EXECUTION MODE ===
# Set to "paper" for safe simulation (default)
# Set to "fake_real" for integration testing
# Set to "real" ONLY with extreme caution - also requires ENABLE_REAL_TRADING=true
BOT_EXECUTION_MODE=paper

# === SAFETY GUARD ===
# BOTH BOT_EXECUTION_MODE=real AND ENABLE_REAL_TRADING=true are required
# for real trading to be activated.  Either alone keeps the bot in paper mode.
ENABLE_REAL_TRADING=false
# Legacy alias (accepted as alternative to ENABLE_REAL_TRADING=true):
# REAL_TRADING_ENABLED=false

# === BOT SETTINGS ===
BOT_PROFILE=default
CONFIG_DIR=config
LOG_LEVEL=INFO

# === TARGET MARKETS (BTC Up/Down) ===
# Comma-separated Polymarket market IDs to trade.
# Defaults to the three BTC horizon markets below when not set.
TARGET_MARKET_IDS=1903731,1903701,1887954
# BTC_5M_MARKET_ID=1903731   (BTC Up/Down 5m)
# BTC_15M_MARKET_ID=1903701  (BTC Up/Down 15m)
# BTC_1H_MARKET_ID=1887954   (BTC Up/Down 1h)

# === POLYMARKET API ===
# Required only for real trading mode
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_WALLET_ADDRESS=

# === BINANCE API (Reference Data) ===
# Optional - used for market context
BINANCE_API_KEY=
BINANCE_API_SECRET=
